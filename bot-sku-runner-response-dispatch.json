                                                     }
                                     },
                      "id":  "if-authorized",
                      "name":  "IF autorizado",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2,
                      "position":  [
                                       520,
                                       260
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "select\n  c.id,\n  c.sku,\n  coalesce(nullif(sp.nombre_producto, \u0027\u0027), nullif(c.marca_producto, \u0027\u0027)) as nombre_producto,\n  coalesce(nullif(sp.marca_producto, \u0027\u0027), nullif(c.marca_producto, \u0027\u0027)) as marca_producto,\n  coalesce(nullif(sp.area, \u0027\u0027), c.area) as area,\n  c.telefono_picker,\n  c.instancia,\n  c.estado,\n  c.respuesta_runner,\n  c.whatsapp_enviado\nfrom public.consultas_sku c\nleft join public.sku_productos sp\n  on upper(sp.sku) = upper(c.sku)\n  and sp.activo = true\nwhere c.id = $1::bigint\n  and c.estado in (\u0027respondido\u0027, \u0027no_disponible\u0027, \u0027en_revision\u0027)\n  and c.whatsapp_enviado = false\nlimit 1;",
                                         "options":  {
                                                         "queryReplacement":  "={{ [ $json.consultaId ] }}"
                                                     }
                                     },
                      "id":  "buscar-consulta",
                      "name":  "Buscar consulta",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       780,
                                       160
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "",
                                                           "name":  "Postgres Supabase/EasyPanel"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "function areaLabel(area) {\n  if (area === \u0027frio\u0027) return \u0027Frio\u0027;\n  if (area === \u0027sala\u0027) return \u0027Sala\u0027;\n  if (area === \u0027gm\u0027) return \u0027GM\u0027;\n  return \u0027Sin area\u0027;\n}\n\nfunction productLine(row) {\n  const product = row.nombre_producto || \u0027Producto sin nombre registrado\u0027;\n  const brand = row.marca_producto || \u0027Sin marca registrada\u0027;\n  return [\n    `SKU ${row.sku}`,\n    `Producto: ${product}`,\n    `Marca: ${brand}`,\n    `Area: ${areaLabel(row.area)}`,\n  ].join(\u0027 | \u0027);\n}\n\nreturn items.map(item =\u003e {\n  const row = item.json;\n  if (!row.id) {\n    return { json: { skip: true, reason: \u0027not_found\u0027 } };\n  }\n\n  const header = productLine(row);\n  const answer = String(row.respuesta_runner || \u0027\u0027).trim();\n  let text;\n\n  if (row.estado === \u0027no_disponible\u0027) {\n    text = `${header}\\nEstado: No disponible.\\nRespuesta: ${answer || \u0027Producto no disponible.\u0027}`;\n  } else if (row.estado === \u0027en_revision\u0027) {\n    text = `${header}\\nEstado: En revision.\\nMensaje: ${answer || \u0027Estamos revisando el producto. Te avisaremos por este mismo chat cuando el runner confirme disponibilidad.\u0027}`;\n  } else {\n    text = `${header}\\nEstado: Disponible.\\nRespuesta: ${answer || \u0027Producto disponible.\u0027}`;\n  }\n\n  return {\n    json: {\n      ...row,\n      texto_whatsapp: text,\n      skip: false\n    }\n  };\n});"
                                     },
