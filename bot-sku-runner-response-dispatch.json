                                                                               {
                                                                                   "id":  "authorized",
                                                                                   "leftValue":  "={{ $json.authorized === true \u0026\u0026 $json.valid === true }}",
                                                                                   "rightValue":  true,
                                                                                   "operator":  {
                                                                                                    "type":  "boolean",
                                                                                                    "operation":  "true",
                                                                                                    "singleValue":  true
                                                                                                }
                                                                               }
                                                                           ],
