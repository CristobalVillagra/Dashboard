                      "id":  "webhook-dispatch",
                      "name":  "Webhook dispatch",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       260
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const headers = $json.headers || {};\nconst secret = headers[\u0027x-webhook-secret\u0027] || headers[\u0027X-Webhook-Secret\u0027] || \u0027\u0027;\nconst expected = $env.N8N_WEBHOOK_SECRET || \u0027\u0027;\n\nif (!expected || secret !== expected) {\n  return [{ json: { authorized: false, error: \u0027Unauthorized\u0027 } }];\n}\n\nconst body = $json.body || $json;\nconst consultaId = body.consultaId ?? body.consulta_id;\n\nif (!consultaId) {\n  return [{ json: { authorized: true, valid: false, error: \u0027consultaId requerido\u0027 } }];\n}\n\nreturn [{ json: { authorized: true, valid: true, consultaId: String(consultaId) } }];"
                                     },
                      "id":  "validar-secret",
                      "name":  "Validar secret",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       260,
                                       260
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict"
                                                                        },
