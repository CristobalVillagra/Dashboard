{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "crons": [
    {
      "path": "/api/admin/cleanup?tipo=inicio_turno",
      "schedule": "0 11 * * 1-6"
    },
    {
      "path": "/api/admin/cleanup?tipo=fin_turno",
      "schedule": "0 1 * * 1-6"
    }
  ]
}

