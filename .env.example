NEXT_PUBLIC_FORMSPARK_ID=

# Supabase: pega aqui tus credenciales para probar.
# SUPABASE_URL es la Project URL del proyecto en Supabase.
# Debe verse asi: https://xxxxx.supabase.co
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Secreto de sesion HMAC (cambia por un string largo aleatorio en produccion).
RUNNER_SESSION_SECRET=CAMBIA_ESTE_SECRETO_LARGO

# ──────────────────────────────────────────────────────────────
# OTP / Autenticacion
# ──────────────────────────────────────────────────────────────

# Webhook OTP unificado (runners, admins y pickers).
# Si esta configurado, se usa para TODOS los roles con el header x-webhook-secret.
# Tu n8n en user-otp-sms ya maneja todos los roles via Twilio.
SMS_OTP_WEBHOOK_URL=https://n8n.aintegration.cl/webhook/user-otp-sms

# Fallback solo para runners/admins si SMS_OTP_WEBHOOK_URL esta vacio.
WHATSAPP_OTP_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────
# n8n Webhooks
# ──────────────────────────────────────────────────────────────

# Secreto compartido con n8n (header x-webhook-secret).
N8N_WEBHOOK_SECRET=CAMBIA_ESTE_SECRETO_COMPARTIDO_CON_N8N

# Despacho de respuesta runner a pickers via WhatsApp (canal whatsapp).
N8N_RUNNER_DISPATCH_WEBHOOK_URL=https://TU-N8N/webhook/runner-response-dispatch

# Despacho de respuesta runner para notificar picker en-app (canal app).
N8N_APP_RUNNER_DISPATCH_WEBHOOK_URL=https://TU-N8N/webhook/app-runner-response-dispatch

# Envio de respaldo a Drive y registro en Sheet.
N8N_BACKUP_WEBHOOK_URL=https://TU-N8N/webhook/app-respaldo-pedido

# ──────────────────────────────────────────────────────────────
# Google (para n8n workflows)
# ──────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_PARENT_ID=TU_ID_CARPETA_DRIVE
GOOGLE_SHEETS_RESPALDOS_ID=TU_ID_SHEET_RESPALDOS
