NEXT_PUBLIC_FORMSPARK_ID=

# Supabase: pega aqui tus credenciales para probar.
# SUPABASE_URL es la Project URL del proyecto en Supabase.
# Debe verse asi: https://xxxxx.supabase.co
# No uses la URL del dashboard tipo https://supabase.com/dashboard/project/xxxxx
# SUPABASE_SERVICE_ROLE_KEY es la service_role key, solo se usa en APIs del servidor.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Cambia este secreto por un texto largo aleatorio antes de producción.
RUNNER_SESSION_SECRET=CAMBIA_ESTE_SECRETO_LARGO

# Opcional: endpoint de tu bot/automatizacion para enviar WhatsApp con el codigo.
# Si lo dejas vacio, en desarrollo la interfaz muestra el codigo dev para probar.
WHATSAPP_OTP_WEBHOOK_URL=
